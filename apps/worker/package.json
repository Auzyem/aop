{
  "name": "@aop/worker",
  "version": "0.0.0",
  "private": true,
  "description": "AOP background job processor — BullMQ",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aop/db": "workspace:*",
    "@aop/types": "workspace:*",
    "@aop/utils": "workspace:*",
    "axios": "^1.15.0",
    "bullmq": "^5.74.1",
    "dotenv": "^16.4.5",
    "ioredis": "5.10.1",
    "@aws-sdk/client-rds": "^3.1031.0",
    "nodemailer": "^6.9.13",
    "handlebars": "^4.7.9",
    "puppeteer": "^22.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.15",
    "ts-node-dev": "^2.0.0",
    "typescript": "*"
  }
}
