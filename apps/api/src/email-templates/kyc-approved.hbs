{{#> base subject="KYC Application Approved — Aurum Operations Platform"}}
  {{#*inline "body"}}
    <h2>KYC Application Approved</h2>
    <p>Dear <strong>{{clientName}}</strong>,</p>
    <p>We are pleased to confirm that your KYC (Know Your Customer) application has been <strong style="color:#16A34A;">approved</strong>. You are now fully verified on the Aurum Operations Platform.</p>

    <div class="stat-box">
      <div class="label">Verified On</div>
      <div class="value" style="font-size:16px;">{{reviewedAt}}</div>
    </div>

    <p>You can now proceed with transactions on the platform. If you have any questions, please contact your assigned agent or our operations team.</p>

    <hr class="divider" />
    <p style="color:#888;font-size:13px;">This verification is subject to ongoing compliance monitoring. We may request updated documents in the future.</p>
  {{/inline}}
{{/base}}
