{
  "name": "@aop/api",
  "version": "0.0.0",
  "private": true,
  "description": "AOP REST API — Express/TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --coverage",
    "test:unit": "jest --coverage --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration --forceExit",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aop/db": "workspace:*",
    "@aop/types": "workspace:*",
    "@aop/utils": "workspace:*",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-ses": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "africastalking": "^0.7.9",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "file-type": "16.5.4",
    "handlebars": "^4.7.9",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.10.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "sanitize-html": "^2.17.3",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/africastalking": "^0.6.0",
    "@types/archiver": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.15",
    "@types/qrcode": "^1.5.5",
    "@types/sanitize-html": "^2.16.1",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "*"
  }
}
