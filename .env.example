# =============================================================================
# Aurum Operations Platform — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://aop:aop@localhost:5432/aop
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---------------------------------------------------------------------------
# Cache / Queue Broker (Redis)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------

# metals.dev — spot gold price feed (https://metals.dev)
METALS_DEV_API_KEY=

# OFAC / UN sanctions screening service
SANCTIONS_API_KEY=
SANCTIONS_API_URL=https://api.sanctions-provider.example.com

# Foreign exchange rates provider
FX_API_KEY=
FX_API_URL=https://api.fx-provider.example.com

# KYC / AML document verification
KYC_API_KEY=
KYC_API_URL=

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=aop-documents

# ---------------------------------------------------------------------------
# Local Dev S3 (MinIO — overrides AWS settings in development)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aop.local

# ---------------------------------------------------------------------------
# Frontend (Next.js — NEXT_PUBLIC_* vars are exposed to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Aurum Operations Platform

# ---------------------------------------------------------------------------
# Background Worker
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY=5

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
# SENTRY_DSN=
